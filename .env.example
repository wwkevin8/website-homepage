SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
USER_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_SECRET=replace-with-a-different-long-random-secret
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
ADMIN_BOOTSTRAP_NAME=system-admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
STORAGE_ORDER_NOTIFY_EMAIL=ops@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="NGN Storage <mailer@example.com>"
STORAGE_ORDER_ADMIN_URL=http://localhost:3000/admin-storage.html
